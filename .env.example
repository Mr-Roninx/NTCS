# Copy to .env and fill values — DO NOT COMMIT secrets to git
# Supabase project URL and anon/public key (use only the anon/public key on the client)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: set to true only when you explicitly want client-side session persistence
# (not recommended for public deployments; prefer secure server-side cookies)
VITE_SUPABASE_PERSIST_SESSION=false
